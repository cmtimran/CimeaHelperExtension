{
  "manifest_version": 3,
  "name": "CIMEA Helper",
  "version": "1.1.0",
  "description": "Automates form filling and navigation for the CIMEA portal. Includes anonymous usage tracking.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "CIMEA Helper Tool"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://freeipapi.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.cimea-diplome.it/*", "*://ecommerce.nexi.it/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["success.mp3"],
      "matches": ["<all_urls>"]
    }
  ]
}
